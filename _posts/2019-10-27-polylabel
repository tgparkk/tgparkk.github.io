    public Cell _get_centroid_cell(List<List<List<int>>> polygon)
    {
        int area = 0;
        int x = 0;
        int y = 0;
        List<List<int>>points= polygon[0];
        List<int> b = points[points.Count-1];

        foreach(List<int>a in points)
        {
            int f = a[0] * b[1] - b[0] * a[1];
            x += (a[0] + b[0]) * f;
            y += (a[1] + b[1]) * f;
            area += f * 3;
            b = a;
        }

        Cell cell = new Cell();
        if (area==0)
        {
            cell.x = points[0][0];
            cell.y = points[0][1];
            cell.polygon = polygon;
            return cell;
        }

        cell.x = x / area;
        cell.y = y / area;
        cell.h = 0;
        cell.polygon = polygon;

        return cell;

    }

