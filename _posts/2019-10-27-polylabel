    public float _point_to_polygon_distance(int x,int y, List<List<List<int>>> polygon)
    {
        bool inside = false;
        float min_dist_sq = 3.402823E+38f;

        foreach(List<List<int>>ring in polygon)
        {
            List<int> b = ring[ring.Count-1];
            foreach(List<int>a in ring)
            {
                if( (a[1]>y) != (b[1]>y) &&
                    ( x < (b[0]-a[0]) * (y-a[1]) / (b[1] -a[1]) +a[0]))
                {
                    inside = inside==true ? false : true;
                }
                min_dist_sq = Math.Min(min_dist_sq, _get_seg_dist_sq(x, y, a, b));
                b = a;

            }
        }

        float result = (float)Math.Sqrt(min_dist_sq);

        if( inside != true )
        {
            return -result;
        }
        else
        {
            return result;
        }

    }

    public int _get_seg_dist_sq(int px,int py,List<int> a,List<int> b)
    {
        int x = a[0];
        int y = a[1];
        int dx = b[0] - x;
        int dy = b[1] - y;

        if(dx!=0 || dy!=0)
        {
            int t = ((px - x) * dx + (py - y) * dy) / (dx * dx + dy * dy);
            if(t>1)
            {
                x = b[0];
                y = b[1];
            }
            else if(t>0)
            {
                x += dx * t;
                y += dy * t;
            }
        }

        dx = px - y;
        dy = py - y;
        return dx * dx + dy * dy; 
    }

