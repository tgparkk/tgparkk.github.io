        [Microsoft.SqlServer.Server.SqlProcedure]
        public static double _point_to_polygon_distance(double x, double y, PolygonXY polygon)
        {
            bool inside = false;
            double min_dist_sq = 3.402823E+38f;
            //SqlGeometry t1 = ;
            foreach (List<PointXY> ring in polygon)//3차원 -> 2차원
            {
                PointXY b = ring[ring.Count - 1];
                foreach (PointXY a in ring)
                {
                    if ((a.Y > y) != (b.Y > y) &&
                        (x < (b.X - a.X) * (y - a.Y) / (b.Y - a.Y) + a.X))
                    {
                        inside = inside == true ? false : true;
                    }
                    min_dist_sq = Math.Min(min_dist_sq, _get_seg_dist_sq(x, y, a, b));
                    b = a;

                }
            }

            double result = Math.Sqrt(min_dist_sq);

            if (inside != true)
            {
                return -result;
            }
            else
            {
                return result;
            }
        }

        [Microsoft.SqlServer.Server.SqlProcedure]
        public static double _get_seg_dist_sq(double px, double py, PointXY a, PointXY b)
        {
            double x = a.X;
            double y = a.Y;
            double dx = b.X - x;
            double dy = b.Y - y;

            if (dx != 0 || dy != 0)
            {
                double t = ((px - x) * dx + (py - y) * dy) / (dx * dx + dy * dy);
                if (t > 1)
                {
                    x = b.X;
                    y = b.Y;
                }
                else if (t > 0)
                {
                    x += dx * t;
                    y += dy * t;
                }
            }

            dx = px - y;
            dy = py - y;
            return dx * dx + dy * dy;
        }

        public struct Cell : IComparable<Cell>
        {
            public double x, y, h;
            public double d, max;
            public PolygonXY polygon;
            public Cell(double x, double y, double h, PolygonXY polygon)
            {
                this.x = x;
                this.y = y;
                this.h = h;
                this.polygon = polygon;
                this.d = _point_to_polygon_distance(x, y, polygon);
                this.max = x + y * (float)Math.Sqrt(2);
            }
            public static bool operator >(Cell self, Cell other)
            {
                return self.CompareTo(other) == 1;
            }
            // Define the is less than operator.
            public static bool operator <(Cell self, Cell other)
            {
                return self.CompareTo(other) == -1;
            }
            // Define the is greater than or equal to operator.
            public static bool operator >=(Cell self, Cell other)
            {
                return self.CompareTo(other) >= 0;
            }
            // Define the is less than or equal to operator.
            public static bool operator <=(Cell self, Cell other)
            {
                return self.CompareTo(other) <= 0;
            }
            public int CompareTo(Cell other)
            {
                throw new NotImplementedException();
            }
            public override bool Equals(object obj)
            {
                if (!(obj is Cell))
                {
                    return false;
                }

                var cell = (Cell)obj;
                return x == cell.x &&
                       y == cell.y &&
                       h == cell.h &&
                       d == cell.d &&
                       max == cell.max &&
                       EqualityComparer<PolygonXY>.Default.Equals(polygon, cell.polygon);
            }
        }

        public struct pq_data : IComparable<pq_data>
        {
            public double a;//-c.max
            public long time;//time.time()
            public Cell c;//c

            public pq_data(double a,long time, Cell c)
            {
                this.a = a;
                this.time = time;
                this.c = c;
            }

            int IComparable<pq_data>.CompareTo(pq_data other)
            {
                if(this.a > other.a)
                {
                    return 1;
                }
                else if(this.a < other.a)
                {
                    return -1;
                }
                else
                {
                    if (this.time > other.time)
                    {
                        return 1;
                    }
                    else if (this.time < other.time)
                    {
                        return -1;
                    }
                    else
                    {
                        if(this.c.max > other.c.max)
                        {
                            return 1;
                        }
                        else
                        {
                            return -1;
                        }
                    }
                }

                throw new NotImplementedException();
            }
        }

        [Microsoft.SqlServer.Server.SqlProcedure]
        public static Cell _get_centroid_cell(PolygonXY polygon)
        {
            double area = 0;
            double x = 0;
            double y = 0;
            List<PointXY> points = polygon[0];
            PointXY b = points[points.Count - 1];

            foreach (PointXY a in points)
            {
                double f = a.X * b.Y - b.X * a.Y;
                x += (a.X + b.X) * f;
                y += (a.Y + b.Y) * f;
                area += f * 3;
                b = a;
            }

            Cell cell = new Cell();
            if (area == 0)
            {
                cell.x = points[0].X;
                cell.y = points[0].Y;
                cell.polygon = polygon;
                return cell;
            }

            cell.x = x / area;
            cell.y = y / area;
            cell.h = 0;
            cell.polygon = polygon;

            return cell;
        }

        [Microsoft.SqlServer.Server.SqlProcedure]
        public static PointXY polylabel(SqlGeometry polygon, double precision, bool debug, bool with_distance)
        {
            PolygonXY pgShape;
            WKBUtil.DecPolygon(out pgShape, polygon.STAsBinary().Value);

            PointXY first_item = pgShape[0][0];
            double min_x = first_item.X;
            double min_y = first_item.Y;
            double max_x = first_item.X;
            double max_y = first_item.Y;

            foreach (PointXY p in pgShape[0])
            {
                if (p.X < min_x) min_x = p.X;
                if (p.Y < min_y) min_y = p.Y;
                if (p.X > max_x) max_x = p.X;
                if (p.Y > max_y) max_y = p.Y;
            }

            double width = max_x - min_x;
            double height = max_y - min_y;
            double cell_size = Math.Min(width, height);
            double h = (cell_size / 2.0);

            PriorityQueue<pq_data> cell_queue = new PriorityQueue<pq_data>();

            if (cell_size == 0)
            {
                PointXY rt = new PointXY();
                if (with_distance)
                {
                    rt.X = min_x;
                    rt.Y = min_y;
                    return rt;
                }
                else
                {
                    rt.X = min_x;
                    rt.Y = min_y;
                    return rt;
                }
            }

            double x = min_x;
            while (x < max_x)
            {
                double y = min_y;
                while (y < max_y)
                {
                    Cell c = new Cell(x + h, y + h, h, pgShape);
                    y += cell_size;

                    DateTime now = DateTime.UtcNow;
                    DateTime startOfUnixEpoch = new DateTime(1970, 1, 1, 0, 0, 0).ToUniversalTime();
             
                    TimeSpan tspan = now - startOfUnixEpoch;
                    long secs = (long)tspan.TotalSeconds;


                    cell_queue.Enqueue(new pq_data(-c.max, secs, c) );

                }
                x += cell_size;
            }

            Cell best_cell = _get_centroid_cell(pgShape);

            Cell bbox_cell = new Cell(min_x + width / 2, min_y + height / 2, 0, pgShape);

            if (bbox_cell.d > best_cell.d)
            {
                best_cell = bbox_cell;
            }

            int num_of_probes = cell_queue.Count();

            while (!( cell_queue.Count() == 0) )
            {
                Cell cell = cell_queue.Peek().c;

                if (cell.d > best_cell.d)
                {
                    best_cell = cell;
                }

                if (cell.max - best_cell.d <= precision) continue;

                double hh = cell.h / 2;
                //
                Cell cc = new Cell(cell.x - h, cell.y - h, h, pgShape);

                DateTime now = DateTime.UtcNow;
                DateTime startOfUnixEpoch = new DateTime(1970, 1, 1, 0, 0, 0).ToUniversalTime();
                TimeSpan tspan = now - startOfUnixEpoch;
                long secs = (long)tspan.TotalSeconds;

                cell_queue.Enqueue(new pq_data(-cc.max, secs, cc));
                //
                cc = new Cell(cell.x + h, cell.y - h, h, pgShape);

                now = DateTime.UtcNow;
                startOfUnixEpoch = new DateTime(1970, 1, 1, 0, 0, 0).ToUniversalTime();
                tspan = now - startOfUnixEpoch;
                secs = (long)tspan.TotalSeconds;

                cell_queue.Enqueue(new pq_data(-cc.max, secs, cc));
                //
                cc = new Cell(cell.x - h, cell.y + h, h, pgShape);

                now = DateTime.UtcNow;
                startOfUnixEpoch = new DateTime(1970, 1, 1, 0, 0, 0).ToUniversalTime();
                tspan = now - startOfUnixEpoch;
                secs = (long)tspan.TotalSeconds;

                cell_queue.Enqueue(new pq_data(-cc.max, secs, cc));
                //
                cc = new Cell(cell.x + h, cell.y + h, h, pgShape);

                now = DateTime.UtcNow;
                startOfUnixEpoch = new DateTime(1970, 1, 1, 0, 0, 0).ToUniversalTime();
                tspan = now - startOfUnixEpoch;
                secs = (long)tspan.TotalSeconds;

                cell_queue.Enqueue(new pq_data(-cc.max, secs, cc));
                //
                num_of_probes += 4;
            }

            PointXY rt_list = new PointXY();
            rt_list.X = best_cell.x;
            rt_list.Y = best_cell.y;
            return rt_list;
        }
